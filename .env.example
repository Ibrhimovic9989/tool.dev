# Copy to .env (or .env.local) and fill in real values. Never commit either.
# On Vercel, add these in Project Settings → Environment Variables.

# ─── Azure OpenAI (chat + embeddings) ──────────────────────────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─── Azure Document Intelligence (OCR for scanned PDFs / images) ───────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# ─── Supabase Postgres (with pgvector + pg_graphql) ────────────────────────
# Use the connection pooler URL (port 6543). Run scripts/bootstrap-db.mjs
# once locally against this URL to create extensions + tables.
DATABASE_URL=

# ─── NextAuth / Auth.js v5 ─────────────────────────────────────────────────
# AUTH_SECRET must be a random 32+ char string. Generate with `openssl rand -base64 32`.
AUTH_SECRET=
# AUTH_URL is only required locally; Vercel sets it automatically.
AUTH_URL=http://localhost:3000
# Required on Vercel previews so callback URLs work behind their proxy.
AUTH_TRUST_HOST=true
# Google OAuth client id + secret from Google Cloud Console.
# Add http://localhost:3000/api/auth/callback/google AND your prod callback
# URL as authorized redirect URIs on the OAuth client.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
